<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:background="@color/white">

    <Button
        android:id="@+id/powrot"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:text="II"
        android:layout_alignParentLeft="true"
        android:layout_marginTop="30dp"
        />

    <TextView
        android:id="@+id/wynik"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:text="Wynik: "
        android:textSize="50sp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="25dp"/>

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/tablica"
        android:layout_marginTop="50dp" />

    <TextView
        android:id="@+id/rejestracja"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:text="RTA"
        android:textSize="68sp"
        android:layout_marginTop="120dp"
        android:layout_marginStart="40dp"
        android:letterSpacing="0.1"
        android:fontFamily="@font/din1451alt"
        android:textAlignment="center"
        android:textColor="@color/black"
        />
    <TextView
        android:layout_width="210dp"
        android:layout_height="wrap_content"
        android:text="12345"
        android:textSize="68sp"
        android:layout_marginTop="120dp"
        android:layout_marginStart="200dp"
        android:letterSpacing="0.1"
        android:fontFamily="@font/din1451alt"
        android:textColor="@color/black"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="30dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/pierwszaOdpowiedz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Odpowiedź 1."
                android:layout_weight="1"
                android:textSize="20sp"
                android:padding="40dp"/>
            <Button
                android:id="@+id/drugaOdpowiedz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Odpowiedź 2."
                android:layout_weight="1"
                android:textSize="20sp"
                android:padding="40dp"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/trzeciaOdpowiedz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Odpowiedź 3."
                android:layout_weight="1"
                android:textSize="20sp"
                android:padding="40dp"/>
            <Button
                android:id="@+id/czwartaOdpowiedz"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Odpowiedź 4."
                android:layout_weight="1"
                android:textSize="20sp"
                android:padding="40dp"/>

        </LinearLayout>

    </LinearLayout>



</RelativeLayout>